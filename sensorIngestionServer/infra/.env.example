# Copia este archivo como .env y ajusta los valores antes de levantar el stack.
# cp .env.example .env

# ── RabbitMQ (contenedor externo) ─────────────────────────────────────────────
# Hostname o IP del contenedor RabbitMQ.
# Si RabbitMQ corre en otro docker-compose en el MISMO host:
#   - Agrega una red externa compartida en ambos compose, o
#   - Usa host.docker.internal (Mac/Windows) / la IP del host (Linux)
RABBITMQ_HOST=rabbitmq

RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
